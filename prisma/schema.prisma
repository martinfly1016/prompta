generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?   // null for OAuth-only / magic-link users; required for CredentialsProvider admins
  name          String?
  image         String?
  role          String    @default("MEMBER") // MEMBER (default end-user), ADMIN, EDITOR
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== AI Tools ====================

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   // e.g. "Stable Diffusion"
  nameJa      String?  // e.g. "ステーブルディフュージョン"
  description String?  @db.Text
  icon        String?  // emoji or icon identifier
  color       String?  // hex color for UI badge
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prompts     Prompt[]
  categories  ToolCategory[]

  @@index([slug])
}

// ==================== Categories ====================

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  nameEn      String?   // English name for SEO
  description String?   @db.Text
  icon        String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  prompts     Prompt[]
  tools       ToolCategory[]

  @@index([slug])
}

// Junction table: Tool <-> Category many-to-many
model ToolCategory {
  id         String   @id @default(cuid())
  toolId     String
  categoryId String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([toolId, categoryId])
  @@index([toolId])
  @@index([categoryId])
}

// ==================== Tags ====================

model Tag {
  id             String    @id @default(cuid())
  name           String    @unique
  slug           String    @unique
  color          String    @default("blue")
  description    String?
  isApproved     Boolean   @default(false) // true = curated tag shown in sitemap/tag pages

  // SEO (per-tag landing page overrides; null = fall back to default template)
  seoTitle       String?
  seoDescription String?
  seoIntro       String?   @db.Text // 400-600 char JP intro rendered above the prompt grid

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  prompts        Prompt[]  @relation("PromptTags")

  @@index([slug])
  @@index([isApproved])
}

// ==================== Prompts ====================

model Prompt {
  id              String    @id @default(cuid())
  slug            String?   @unique
  title           String
  description     String
  content         String    @db.Text

  // Relations
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId      String
  tool            Tool?     @relation(fields: [toolId], references: [id], onDelete: SetNull)
  toolId          String?
  tags            Tag[]     @relation("PromptTags")

  // Legacy: JSON string tags for backward compat during migration
  tagsJson        String?   @map("tags")

  // SEO
  seoTitle        String?
  seoDescription  String?

  // Metadata
  author          String?
  difficulty      String?   @default("beginner") // beginner, intermediate, advanced
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)

  // Stats
  viewCount       Int       @default(0)
  copyCount       Int       @default(0)

  // Collection source tracking
  sourceUrl       String?   // URL where this prompt was collected from
  isAutoCollected Boolean   @default(false) // true = auto-collected by skill, false = manual

  // photo-edit Before/After 効果サンプル (Vercel Blob URLs)
  sampleBeforeUrl String?
  sampleAfterUrl  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  images          PromptImage[]

  @@index([categoryId])
  @@index([toolId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([slug])
}

// ==================== Prompt Images ====================

model PromptImage {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  url       String
  blobKey   String
  fileName  String
  fileSize  Int
  mimeType  String
  width     Int?
  height    Int?

  imageType String   @default("effect") // "effect" or "original"
  order     Int      @default(0)
  altText   String?

  parentImageId  String?
  parentImage    PromptImage?  @relation("OriginalToEffect", fields: [parentImageId], references: [id], onDelete: Cascade)
  originalImages PromptImage[] @relation("OriginalToEffect")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([promptId])
  @@index([order])
  @@index([imageType])
  @@index([parentImageId])
}

// ==================== Guides ====================

model Guide {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  description     String?   @db.Text
  content         String    @db.Text // Markdown or structured JSON
  targetKeyword   String?
  seoTitle        String?
  seoDescription  String?
  isPublished     Boolean   @default(false)
  order           Int       @default(0)
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
}

// ==================== Tool Usage Quota ====================

model ToolUsage {
  id          String   @id @default(cuid())
  anonId      String
  ipHash      String
  tool        String
  type        String   @default("free")
  emailHash   String?  // set when type="paid"
  createdAt   DateTime @default(now())

  @@index([anonId, tool, createdAt])
  @@index([ipHash, tool, createdAt])
  @@index([emailHash, tool, createdAt])
}

model PaidCredits {
  id           String   @id @default(cuid())
  emailHash    String   @unique
  email        String
  balance      Int      @default(0)
  totalEarned  Int      @default(0)
  totalUsed    Int      @default(0)
  lastPurchase DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StripePayment {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  paymentIntent  String?
  emailHash      String
  email          String
  amountJpy      Int
  creditsGranted Int
  status         String   // "pending" | "paid" | "refunded"
  rawEventType   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([emailHash])
  @@index([status])
}
